context:
  name: sofa-glfw
  version: "26.06.dev%DATE_YYYYMMDD%"
  build_num: 0
  major: ${{ (version | split('.'))[0] }}
  minor: ${{ (version | split('.'))[1] }}
  major_minor: ${{ major }}.${{ minor }}
  git_sha: %GIT_SHA%
  sofa_git_sha: %SOFA_GIT_SHA%
  sofa_python3_git_sha: %SOFA_PYTHON3_GIT_SHA%

package:
  name: ${{ name }}
  version: ${{ version }}

build:
  number: 0

source:
  git: https://github.com/sofa-framework/SofaGLFW.git
  branch: master

requirements:
  build:
    - ${{ compiler('cxx') }}
    - ${{ stdlib('c') }}
    - cmake
    - ninja
    - if: build_platform != target_platform
      then:
        - python
        - cross-python_${{ target_platform }}
        - pybind11        
  host:
    - sofa-devel ${{ major_minor }}.dev* dev_${{ sofa_git_sha[:7] }}
    - sofa-python3 ${{ major_minor }}.dev* dev_${{ sofa_python3_git_sha[:7] }}_py${{ python | version_to_buildstring }}
    - sofa-gl ${{ major_minor }}.dev* dev_${{ sofa_git_sha[:7] }}
    - nativefiledialog-extended
    - glfw
    - pybind11
    - python
  run:
    - python
    # sofa-glfw is a devel library so it needs sofa-devel at runtime
    - sofa-devel ${{ major_minor }}.dev* dev_${{ sofa_git_sha[:7] }}
    - sofa-python3 ${{ major_minor }}.dev* dev_${{ sofa_python3_git_sha[:7] }}_py${{ python | version_to_buildstring }}
  run_exports:
    - ${{ pin_subpackage(name, upper_bound='x.x') }}

tests:
  - package_contents:
      include:
        - SofaGLFW/SofaGLFW/config.h
        - SofaImGui/SofaImGui/config.h
      lib: 
        - SofaGLFW
        - SofaImGui
  - script:
      - cmake-package-check SofaGLFW SofaImGui
    requirements:
      run:
        - cmake-package-check
        - ${{ compiler('c') }}
        - ${{ compiler('cxx') }}

about:
  homepage: https://www.sofa-framework.org/applications/plugins/modern-gui-using-glfw/
  summary: Quick and simple GUI for SOFA, based on GLFW and Dear ImGui.
  license: LGPL-3.0-or-later
  license_file:
    - LICENSE
    - 3rdparty-licenses/IconFontCppHeaders/LICENSE.txt # ZLIB
    - 3rdparty-licenses/imgui/LICENSE.txt # MIT
    - 3rdparty-licenses/implot/LICENSE.txt # MIT
  repository: https://github.com/sofa-framework/SofaGLFW

extra:
  recipe-maintainers:
    - olivier-roussel
    - hugtalbot
    - bakpaul
